<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="#F0F4F8">

    <!-- 标题 -->
    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginBottom="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/titleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RPGM Decrypter"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#2C3E50" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="基于 Petschko/RPG-Maker-MV-Decrypter"
            android:textSize="12sp"
            android:textColor="#7F8C8D"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- 密钥输入区 -->
    <androidx.cardview.widget.CardView
        android:id="@+id/keyCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        android:layout_marginBottom="12dp"
        app:layout_constraintTop_toBottomOf="@id/headerLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp">

            <TextView
                android:id="@+id/keyLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔑 加密密钥（hex，可选）"
                android:textSize="13sp"
                android:textColor="#34495E"
                android:textStyle="bold"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <EditText
                android:id="@+id/keyInput"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:hint="留空 = 无密钥模式（跳过头部）"
                android:textSize="14sp"
                android:inputType="text"
                android:fontFamily="monospace"
                android:background="@drawable/key_input_bg"
                android:paddingHorizontal="10dp"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                app:layout_constraintTop_toBottomOf="@id/keyLabel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/detectKeyButton"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:text="🔍 从文件检测"
                android:textSize="12sp"
                android:textColor="#3498DB"
                app:layout_constraintTop_toBottomOf="@id/keyInput"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/loadKeyFromFileButton"
                android:layout_marginTop="6dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/loadKeyFromFileButton"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:text="📂 从 System.json 导入"
                android:textSize="12sp"
                android:textColor="#2ECC71"
                app:layout_constraintTop_toBottomOf="@id/keyInput"
                app:layout_constraintStart_toEndOf="@id/detectKeyButton"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="6dp" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

    <!-- 文件信息卡片 -->
    <androidx.cardview.widget.CardView
        android:id="@+id/fileInfoCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        android:layout_marginBottom="12dp"
        app:layout_constraintTop_toBottomOf="@id/keyCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/fileInfoText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="未选择文件"
            android:textSize="14sp"
            android:textColor="#34495E"
            android:padding="14dp"
            android:lineSpacingExtra="4dp" />
    </androidx.cardview.widget.CardView>

    <!-- 按钮 -->
    <!-- 操作按钮行 -->
    <LinearLayout
        android:id="@+id/buttonRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="3"
        android:layout_marginBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/fileInfoCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/selectFilesButton"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="📂 选文件"
            android:textSize="12sp"
            android:textColor="#3498DB"
            app:strokeColor="#3498DB"
            app:cornerRadius="10dp"
            android:layout_marginEnd="4dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/validatePngButton"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="🔍 检查 PNG"
            android:textSize="12sp"
            android:textColor="#9B59B6"
            app:strokeColor="#9B59B6"
            app:cornerRadius="10dp"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/selectOutputButton"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="📁 输出目录"
            android:textSize="12sp"
            android:textColor="#2ECC71"
            app:strokeColor="#2ECC71"
            app:cornerRadius="10dp"
            android:layout_marginStart="4dp" />

    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/decryptButton"
        style="@style/Widget.Material3.Button"
        android:layout_width="0dp"
        android:layout_height="54dp"
        android:text="请选择文件"
        android:textSize="16sp"
        android:enabled="false"
        app:cornerRadius="12dp"
        android:textColor="#FFFFFF"
        app:backgroundTint="#3498DB"
        android:layout_marginBottom="12dp"
        app:layout_constraintTop_toBottomOf="@id/buttonRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 结果 -->
    <ScrollView
        android:id="@+id/resultScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/decryptButton"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <TextView
                android:id="@+id/resultText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#2C3E50"
                android:fontFamily="monospace"
                android:padding="14dp"
                android:lineSpacingExtra="2dp" />
        </androidx.cardview.widget.CardView>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
